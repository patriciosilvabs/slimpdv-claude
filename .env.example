# Database Configuration
DB_NAME=slimpdv
DB_USER=slimpdv
DB_PASSWORD=your-strong-password-here

# Backend Configuration
NODE_ENV=production
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRY=7d
PORT=5000

# Frontend Configuration
VITE_API_URL=https://www.pdvslim.com.br/api
VITE_AUTH_URL=https://www.pdvslim.com.br/auth
FRONTEND_URL=https://www.pdvslim.com.br

# Supabase (placeholder - application uses local API backend)
VITE_SUPABASE_URL=https://placeholder.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=placeholder-key

# Optional: Monitoring and Logging
LOG_LEVEL=info
ENABLE_METRICS=true
